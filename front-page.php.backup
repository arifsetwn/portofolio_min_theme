<!-- Publikasi Terbaru -->
<section id="publikasi-terbaru">
  <h2><span class="section-emoji">📄</span>Publikasi Terbaru</h2>
  <?php
  $publications = new WP_Query( array(
    'post_type' => 'publikasi',
    'posts_per_page' => 3,
    'orderby' => 'date',
    'order' => 'DESC',
  ) );
  
  if ( $publications->have_posts() ) :
    while ( $publications->have_posts() ) : $publications->the_post();
    $year = get_post_meta( get_the_ID(), 'year', true );
    $journal = get_post_meta( get_the_ID(), 'journal', true );
    $authors = get_post_meta( get_the_ID(), 'authors', true );
    $pub_url = get_post_meta( get_the_ID(), 'url', true );
    $keywords = get_post_meta( get_the_ID(), 'keywords', true );
  ?>
  <div class="card">
    <p class="card-meta"><?php echo esc_html( $year ); ?> · <?php echo esc_html( $journal ); ?></p>
    <p class="card-title"><a href="<?php echo esc_url( $pub_url ?: get_permalink() ); ?>" target="_blank" style="color:#1a1a1a;text-decoration:none;"><?php the_title(); ?></a></p>
    <p style="font-size:0.82rem;color:#6b6b6b;margin:0.25rem 0 0.5rem;"><?php echo esc_html( $authors ); ?></p>
    <?php if ( $keywords ) : 
      $keyword_array = explode( ' ', $keywords );
      foreach ( $keyword_array as $kw ) :
    ?>
    <span class="tag"><?php echo esc_html( $kw ); ?></span>
    <?php 
      endforeach;
    endif; ?>
  </div>
  <?php
    endwhile;
    wp_reset_postdata();
  else :
  ?>
  <div class="card">
    <p class="card-meta">2024 · Jurnal Pendidikan Teknologi</p>
    <p class="card-title">Pengembangan Media Pembelajaran Berbasis Web untuk Meningkatkan Kompetensi Mahasiswa</p>
    <p style="font-size:0.82rem;color:#6b6b6b;margin:0.25rem 0 0.5rem;">Arif Setiawan, et al.</p>
    <span class="tag">e-learning</span><span class="tag">media pembelajaran</span>
  </div>
  <?php endif; ?>
  <a href="<?php echo esc_url( home_url( '/penelitian' ) ); ?>" style="font-size:0.82rem;color:#1a5276;">Lihat semua publikasi →</a>
</section>

